RPC_URL=https://api.mainnet-beta.solana.com
WS_URL=

# Wallet to copy
TARGET_WALLET=

# Your trading wallet secret key in base58 format
TRADER_SECRET_KEY=

# Copy buy config
COPY_BUY_SIZE_IN_QUOTE=10
DEFAULT_QUOTE_MINT=So11111111111111111111111111111111111111112
SLIPPAGE_BPS=200
DRY_RUN=true

# Sell mode:
# true  -> use own TP/SL logic
# false -> sell when target wallet sells
USE_OWN_SELL_LOGIC=true
TAKE_PROFIT_PCT=25
STOP_LOSS_PCT=15
SELL_LOGIC_POLL_INTERVAL_MS=8000

# Monitor poll interval
MONITOR_POLL_INTERVAL_MS=3000

# JSON map: token mint -> whirlpool address
# Example:
# {"Es9vMFrzaCERmJfrF4H2m6qjUpBAkLTUEX2UjsFvdcJG":"HJPjoWUrhoZzkRDeo63eFUsVTNff7kwh28ykVfoUfH8v"}
POOL_MAP_JSON={}

# State / gather output paths
STATE_FILE_PATH=.data/state.json
GATHER_OUTPUT_PATH=.data/gather.json
